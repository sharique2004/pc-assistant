# ============================================================
# PC Assistant - Backend environment variables (EXAMPLE)
# ============================================================
# Copy this file to ".env" in the same directory and fill in
# the values for your machine.
#
#   cp .env.example .env       (mac / git bash)
#   copy .env.example .env     (Windows cmd)
#
# NEVER commit your real .env - it is excluded by .gitignore.
# ============================================================

# -- Flask server -------------------------------------------------------------
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false

# -- CORS ---------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -- Ollama  (runs locally, no API key) ---------------------------------------
OLLAMA_HOST=http://localhost:11434

# Model used by voice_intent.py to classify intent.
INTENT_MODEL=mistral

# Model used by executor.create_app to generate code.
# Pull this with:  ollama pull qwen2.5-coder:14b
CODEGEN_MODEL=qwen2.5-coder:14b

# -- Whisper  (local speech-to-text) ------------------------------------------
# Options: tiny | base | small | medium | large
WHISPER_MODEL=small
ASR_BACKEND=auto

# -- Audio capture ------------------------------------------------------------
AUDIO_SAMPLE_RATE=16000
AUDIO_MAX_DURATION_S=10
VAD_SILENCE_THRESHOLD=0.003
VAD_SILENCE_DURATION_S=1.5
OLLAMA_INTENT_TIMEOUT_S=120
WAKE_WORD=Bibi
WAKE_WORD_MODEL=tiny
WAKE_WORD_LANGUAGE=en
WAKE_SAMPLE_RATE=16000
WAKE_CHUNK_DURATION_S=1.2
WAKE_SIGNAL_THRESHOLD=0.008
WAKE_COOLDOWN_S=1.0

# Directory for temporary WAV files. Must exist and be writable.
# Replace YOUR_USER with your Windows user folder.
AUDIO_TMP_DIR=C:/Users/YOUR_USER/VoiceAsistant/pc-assistant/tmp

# Confidence below this value forces the intent to "clarify".
CLARIFY_THRESHOLD=0.5

# -- Optional hybrid cloud decision routing (disabled by default) -------------
DECISION_ROUTER_MODE=local
CLOUD_DECISION_PROVIDER=gemini
CLOUD_DECISION_MODEL=gemini-2.5-flash-lite
CLOUD_DECISION_TIMEOUT_S=8
CLOUD_DECISION_MAX_CHARS=140
GEMINI_API_KEY=

# -- Claude Code task runner ---------------------------------------------------
# How `create_app` invokes Claude Code:
#   interactive (default) -> spawns a new Windows Terminal window with
#       `claude` running so you can watch it build the app and intervene.
#       The Flask /confirm response returns immediately - no captured summary.
#   headless              -> runs `claude --print` and captures stdout into
#       the /confirm response, then opens VS Code on success.  Use when you
#       want a non-interactive batch run (CI, automated tests).
CLAUDE_TASK_MODE=interactive
# Override the Claude model used for create_app runs (defaults to Claude's
# CLI default - usually Sonnet). Examples: "opus", "sonnet", or a model id.
CLAUDE_TASK_MODEL=
# Timeout only applies in headless mode.
CLAUDE_TASK_TIMEOUT_S=600

# -- Executor -----------------------------------------------------------------
# Comma-separated directories the executor may write to.
# Replace YOUR_USER with your Windows user folder.
ALLOWED_PATHS=C:/Users/YOUR_USER,C:/Users/YOUR_USER/Desktop,C:/Users/YOUR_USER/Documents,C:/Users/YOUR_USER/Downloads

# Default directory for new files and generated projects.
WORKSPACE_DIR=C:/Users/YOUR_USER

# Path to VS Code executable (used by executor.create_app).
VSCODE_PATH=C:/Users/YOUR_USER/AppData/Local/Programs/Microsoft VS Code/Code.exe

# Extra directories to search when resolving app names (semicolon-separated).
APP_SEARCH_PATHS=C:/Program Files;C:/Program Files (x86);C:/Users/YOUR_USER/AppData/Local/Programs
GENERAL_PLANNER_MAX_STEPS=3
GENERAL_PLANNER_TIMEOUT_S=25

# -- PC State -----------------------------------------------------------------
RECENT_FILES_DIRS=C:/Users/YOUR_USER/Desktop,C:/Users/YOUR_USER/Documents,C:/Users/YOUR_USER/Downloads,C:/Users/YOUR_USER
RECENT_FILES_LIMIT=10
DISK_PATH=C:/
