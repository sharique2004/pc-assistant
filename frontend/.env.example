# ============================================================
# PC Assistant - Frontend environment variables (EXAMPLE)
# ============================================================
# Copy this file to ".env" in the same directory:
#
#   cp .env.example .env       (mac / git bash)
#   copy .env.example .env     (Windows cmd)
#
# Vite only exposes VITE_-prefixed variables to client code.
# NEVER store secrets here - this file is bundled into the build.
# ============================================================

# Base URL of the Flask backend. The Vite proxy uses this as the
# target for /command, /system-state, /health, /confirm, and /tts.
VITE_API_BASE_URL=http://localhost:5000

# Dev server port
VITE_PORT=5173

# How often SystemPanel polls /system-state (milliseconds)
VITE_POLL_INTERVAL_MS=5000
